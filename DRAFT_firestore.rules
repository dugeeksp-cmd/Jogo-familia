rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Pillar 2: Validation Blueprints
    function isValidRoom(data) {
      return data.keys().hasAll(['code', 'status', 'parentPlayerId', 'createdAt']) &&
             data.code is string && data.code.size() <= 20 &&
             data.status in ['waiting', 'playing', 'paused', 'finished'] &&
             data.parentPlayerId is string && data.parentPlayerId.size() <= 64 &&
             data.createdAt is timestamp;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'joinedAtMs']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 50 &&
             data.role in ['child', 'parent', 'guest'] &&
             data.joinedAtMs is number;
    }

    function isValidGuess(data) {
      return data.keys().hasAll(['playerId', 'playerName', 'text', 'status', 'createdAt']) &&
             data.playerId is string && data.playerId.size() <= 64 &&
             data.playerName is string && data.playerName.size() <= 50 &&
             data.text is string && data.text.size() <= 500 &&
             data.status in ['pending', 'correct', 'wrong'] &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'senderName', 'text', 'createdAt']) &&
             data.chatId is string && data.chatId.size() <= 50 &&
             data.senderId is string && data.senderId.size() <= 64 &&
             data.senderName is string && data.senderName.size() <= 50 &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    match /rooms/{roomCode} {
      // Pillar 3: Path Variable Hardening
      allow get: if isValidId(roomCode);
      allow list: if false; // No blanket listing of rooms
      
      // Pillar 4 & 7: Write logic
      allow create: if isValidRoom(incoming());
      allow update: if isValidRoom(incoming()) && (
        // Action: Generic update (by Parent)
        (incoming().diff(existing()).affectedKeys().hasOnly([
            'status', 'currentTurnPlayerId', 'gameStarted', 'roundNumber', 
            'timer', 'filters', 'meeting', 'maxPlayers', 
            'publicChatHiddenForGuests', 'gameObjective'
        ]))
      );

      match /players/{playerId} {
        allow read: if isValidId(playerId);
        allow create: if isValidId(playerId) && isValidPlayer(incoming());
        allow update: if isValidId(playerId) && isValidPlayer(incoming()) && (
            // Anyone can join/update status, or Parent updates score/emoji
            incoming().diff(existing()).affectedKeys().hasAny(['score', 'online', 'joinedAtMs', 'emoji'])
        );
      }

      match /privateHands/{playerId} {
        allow read: if isValidId(playerId);
        allow write: if isValidId(playerId);
      }

      match /messages/{messageId} {
        allow read: if isValidId(messageId);
        allow create: if isValidId(messageId) && isValidMessage(incoming());
      }

      match /guesses/{guessId} {
        allow read: if isValidId(guessId);
        allow create: if isValidId(guessId) && isValidGuess(incoming());
        allow update: if isValidId(guessId) && isValidGuess(incoming()) && (
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'respondedAt'])
        );
      }

      match /scoreHistory/{historyId} {
        allow read: if isValidId(historyId);
        allow create: if isValidId(historyId);
      }
    }
  }
}
