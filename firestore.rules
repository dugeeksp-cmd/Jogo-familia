rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'papai@sabermidia.com.br' || 
        request.auth.token.email == 'dugeeksp@gmail.com'
      ); 
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    function isFamily() {
      return isSignedIn() && (
        isAdmin() ||
        request.auth.token.email in ['miguel@sabermidia.com.br', 'sophia@sabermidia.com.br', 'papai@sabermidia.com.br', 'dugeeksp@gmail.com'] ||
        (request.auth.token.name in ['Miguel', 'Sophia', 'Papai', 'Miguel Sabermidia', 'Sophia Sabermidia', 'Papai Sabermidia']) ||
        request.auth.token.display_name in ['Miguel', 'Sophia', 'Papai']
      );
    }

    // --- Guest Users ---
    match /guestUsers/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Game Rooms ---
    match /gameRooms/{gameRoomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == existing().createdBy);
    }

    match /gameRooms/{gameRoomId}/players/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /gameRooms/{gameRoomId}/hands/{playerId} {
      allow read, write: if isSignedIn();
    }

    // --- Rooms & Sub-collections ---
    match /rooms/{roomCode} {
      allow read, write: if isSignedIn();
    }

    match /rooms/{roomCode}/players/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /rooms/{roomCode}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /rooms/{roomCode}/guesses/{guessId} {
      allow read, write: if isSignedIn();
    }

    match /rooms/{roomCode}/privateHands/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /rooms/{roomCode}/scoreHistory/{historyId} {
      allow read, create: if isSignedIn();
    }
  }
}
