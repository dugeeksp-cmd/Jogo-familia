rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'papai@sabermidia.com.br'; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- Guest Users ---
    match /guestUsers/{uid} {
      function isValidGuest(data) {
        return data.keys().hasAll(['uid', 'username', 'email', 'displayName', 'role', 'chatColor', 'createdAt', 'updatedAt'])
          && data.uid == request.auth.uid
          && data.role == 'guest'
          && data.username is string && data.username.size() <= 64
          && data.chatColor is string && data.chatColor.size() == 7
          && data.email == request.auth.token.email;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGuest(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(uid) && isValidGuest(incoming()) 
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt == request.time;
    }

    match /usernames/{username} {
      allow read: if true; // Needed for login check
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if false; // Usernames are usually immutable once taken in this simplified logic
    }

    // --- Rooms & Sub-collections ---
    match /rooms/{roomCode} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only Papai manages room status/passwords
    }

    match /rooms/{roomCode}/players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Players update their own online status/score history
    }

    match /rooms/{roomCode}/messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['chatId', 'senderId', 'senderName', 'senderRole', 'senderColor', 'text', 'createdAt', 'createdAtMs'])
          && data.text is string && data.text.size() <= 1000
          && data.senderId is string
          && data.chatId is string;
      }

      allow read: if isSignedIn() && (
        existing().chatId == 'group' || 
        (existing().chatId == 'family' && isAdmin()) || // Simplified check, family role not in auth token
        (existing().senderId == request.auth.uid) // Simplified
      );

      // We allow reading 'group' for everyone. 
      // 'family' should be restricted further if needed, but since children use anonymous auth, 
      // we check custom logic in app.
      
      allow create: if isSignedIn() && isValidMessage(incoming()) && (
        incoming().chatId == 'group' || 
        (incoming().chatId != 'family' || incoming().senderRole != 'guest')
      );
    }

    match /rooms/{roomCode}/guesses/{guessId} {
      allow read, create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /rooms/{roomCode}/privateHands/{playerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /rooms/{roomCode}/scoreHistory/{historyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
    }
  }
}
