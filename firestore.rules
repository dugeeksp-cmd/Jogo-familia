rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'papai@sabermidia.com.br'; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    function isFamily() {
      return isSignedIn() && (
        request.auth.token.email in ['miguel@sabermidia.com.br', 'sophia@sabermidia.com.br', 'papai@sabermidia.com.br'] ||
        (request.auth.token.name in ['Miguel', 'Sophia', 'Papai'])
      );
    }

    // --- Guest Users ---
    match /guestUsers/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Game Rooms ---
    match /gameRooms/{gameRoomId} {
      function canCreateRoom() {
        return isFamily() || isAdmin();
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn() && canCreateRoom();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.createdBy || isAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['joinedPlayers', 'invitedPlayers', 'status', 'gameStarted', 'currentTurnPlayerId', 'roundNumber', 'timer']))
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.createdBy);
    }

    match /gameRooms/{gameRoomId}/players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /gameRooms/{gameRoomId}/hands/{playerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/gameRooms/$(gameRoomId)).data.createdBy);
    }

    // --- Rooms & Sub-collections ---
    match /rooms/{roomCode} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only Papai manages room status/passwords
    }

    match /rooms/{roomCode}/players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Players update their own online status/score history
    }

    match /rooms/{roomCode}/messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['chatId', 'senderId', 'senderName', 'senderRole', 'senderColor', 'text', 'createdAt', 'createdAtMs'])
          && data.text is string && data.text.size() <= 1000
          && data.senderId is string
          && data.chatId is string;
      }

      allow read: if isSignedIn() && (
        existing().chatId == 'group' || 
        (existing().chatId == 'family' && isFamily()) ||
        (existing().chatId.startsWith('private-') && (
          existing().senderId == request.auth.uid || 
          existing().chatId.matches('.*' + request.auth.uid + '.*') ||
          isFamily() // Family members (esp Papai) can read their relevant private chats
        ))
      );

      // We allow reading 'group' for everyone. 
      // 'family' should be restricted further if needed, but since children use anonymous auth, 
      // we check custom logic in app.
      
      allow create: if isSignedIn() && isValidMessage(incoming()) && (
        incoming().chatId == 'group' || 
        (incoming().chatId == 'family' && isFamily()) ||
        incoming().chatId.startsWith('private-')
      );
    }

    match /rooms/{roomCode}/guesses/{guessId} {
      allow read, create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /rooms/{roomCode}/privateHands/{playerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /rooms/{roomCode}/scoreHistory/{historyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
    }
  }
}
